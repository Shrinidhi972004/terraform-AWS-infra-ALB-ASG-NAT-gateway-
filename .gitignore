# Local terraform working directory
.terraform/

# Terraform state files - never commit these
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Terraform plan output files
*.tfplan

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Sensitive variable files - contains your IP, keys etc
*.tfvars

# Mac OS
.DS_Store

# Editor directories
.idea/
.vscode/